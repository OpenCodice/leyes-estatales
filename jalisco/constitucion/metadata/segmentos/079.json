      "ruta": "Artículo 79º › párrafo 1",
      "texto": "Los municipios, a través de sus ayuntamientos, tendrán a su cargo las siguientes funciones y servicios públicos:"
    },
    {
      "id": "079.I",
      "tipo": "fraccion",
      "marca": "I",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción I",
      "texto": "I. Agua potable, drenaje, alcantarillado, tratamiento y disposición de sus aguas residuales;"
    },
    {
      "id": "079.II",
      "tipo": "fraccion",
      "marca": "II",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción II",
      "texto": "II. Alumbrado público;"
    },
    {
      "id": "079.III",
      "tipo": "fraccion",
      "marca": "III",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción III",
      "texto": "III. Aseo público, recolección, traslado, tratamiento y disposición final de los residuos de su competencia;"
    },
    {
      "id": "079.IV",
      "tipo": "fraccion",
      "marca": "IV",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción IV",
      "texto": "IV. Mercados y centrales de abastos;"
    },
    {
