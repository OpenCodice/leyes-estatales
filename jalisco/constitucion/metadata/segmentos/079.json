      "marca": "VI",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción VI",
      "texto": "VI. Cementerios;"
    },
    {
      "id": "079.VII",
      "tipo": "fraccion",
      "marca": "VII",
      "apartado": "",
      "fraccion": "",
      "ruta": "Artículo 79º › Fracción VII",
      "texto": "VII. Rastro;"
